{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "categorie",
    "pluralName": "categories",
    "displayName": "Catégorie",
    "description": "Catégories d'équipes (ex. Seniors, U15…)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "nom": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nom",
      "required": true
    },
    "ordre": {
      "type": "integer",
      "default": 0
    },
    "equipes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::equipe.equipe",
      "mappedBy": "categorie"
    }
  }
}
